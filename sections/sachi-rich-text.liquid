{% comment %}
  Sachi Rich Text (Brand Story) - Paste in theme/sections/
  Centered text + optional link. Use for "SACHI is founded on..." block.
{% endcomment %}

<section class="sachi-rich-text section-{{ section.id }}-padding">
  <div class="sachi-rich-text__container">
    {% if section.settings.heading != blank %}
      <h2 class="sachi-rich-text__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.text != blank %}
      <div class="sachi-rich-text__body">{{ section.settings.text }}</div>
    {% endif %}
    {% if section.settings.link_label != blank and section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="sachi-rich-text__link">{{ section.settings.link_label }}</a>
    {% endif %}
  </div>
</section>

<style>
  .sachi-rich-text {
    background: #f9fafb;
    padding: 3rem 1rem;
  }
  @media (min-width: 750px) { .sachi-rich-text { padding: 4rem 2rem; } }

  .sachi-rich-text__container {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .sachi-rich-text__heading {
    font-size: 1.25rem;
    margin: 0 0 1rem;
    line-height: 1.625;
  }
  @media (min-width: 750px) { .sachi-rich-text__heading { font-size: 1.5rem; margin-bottom: 1.5rem; } }
  @media (min-width: 990px) { .sachi-rich-text__heading { font-size: 1.875rem; } }

  .sachi-rich-text__body {
    font-size: 1rem;
    line-height: 1.625;
    margin-bottom: 1rem;
  }
  .sachi-rich-text__body p { margin: 0 0 0.5em; }
  .sachi-rich-text__body p:last-child { margin-bottom: 0; }

  .sachi-rich-text__link {
    display: inline-block;
    font-size: 1.125rem;
    text-decoration: underline;
    letter-spacing: 0.05em;
    margin-top: 0.5rem;
  }
  .sachi-rich-text__link:hover { text-decoration: none; }
</style>

{% schema %}
{
  "name": "Sachi Rich Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading / Quote",
      "default": "SACHI is founded on the belief that premium quality stylish home textiles shouldn't break the bank."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Additional text"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Sustainability and Values"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Sachi Rich Text",
      "settings": {
        "heading": "SACHI is founded on the belief that premium quality stylish home textiles shouldn't break the bank.",
        "link_label": "Sustainability and Values"
      }
    }
  ]
}
{% endschema %}
