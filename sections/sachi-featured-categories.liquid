{% comment %}
  Sachi Featured Categories - Paste in theme/sections/
  Three image cards (e.g. Sheets, Duvets, Quilts). Add to Homepage.
{% endcomment %}

<section class="sachi-featured-categories section-{{ section.id }}-padding">
  <div class="sachi-featured-categories__container page-width">
    <div class="sachi-featured-categories__grid">
      {% for block in section.blocks %}
        <div class="sachi-featured-categories__item" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: '#' }}" class="sachi-featured-categories__link">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | escape }}"
                width="600"
                height="750"
                loading="lazy"
                class="sachi-featured-categories__image"
              >
            {% else %}
              <div class="sachi-featured-categories__placeholder">{{ 'collection-1' | placeholder_svg_tag }}</div>
            {% endif %}
            <span class="sachi-featured-categories__title">{{ block.settings.title }}</span>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .sachi-featured-categories__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }
  @media (min-width: 750px) { .sachi-featured-categories__container { padding: 4rem 2rem; } }
  @media (min-width: 990px) { .sachi-featured-categories__container { padding: 5rem 2rem; } }

  .sachi-featured-categories__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 750px) {
    .sachi-featured-categories__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
  @media (min-width: 990px) { .sachi-featured-categories__grid { gap: 2rem; } }

  .sachi-featured-categories__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .sachi-featured-categories__link {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .sachi-featured-categories__image,
  .sachi-featured-categories__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sachi-featured-categories__placeholder { background: #f5f5f5; }

  .sachi-featured-categories__title {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    padding: 1rem 1.5rem;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    white-space: nowrap;
    transition: background 0.2s;
  }
  @media (min-width: 750px) { .sachi-featured-categories__title { font-size: 1rem; } }
  .sachi-featured-categories__link:hover .sachi-featured-categories__title {
    background: #f5f5f5;
  }
</style>

{% schema %}
{
  "name": "Sachi Featured Categories",
  "tag": "section",
  "class": "section",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "SHEETS"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sachi Featured Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "SHEETS" }},
        { "type": "category", "settings": { "title": "DUVETS" }},
        { "type": "category", "settings": { "title": "QUILTS" }}
      ]
    }
  ]
}
{% endschema %}
