{% comment %}
  Sachi Video - Paste in theme/sections/
  Embeds Vimeo/YouTube. Dawn has a native video section; this matches your layout.
{% endcomment %}

<section class="sachi-video section-{{ section.id }}-padding">
  <div class="sachi-video__container page-width">
    <div class="sachi-video__wrapper">
      {% if section.settings.video_url != blank %}
        {% assign video_url = section.settings.video_url | downcase %}
        {% if video_url contains 'vimeo.com' %}
          {% assign vimeo_id = section.settings.video_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first %}
          <iframe
            src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay=0&loop=0&autopause=0"
            class="sachi-video__iframe"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            title="Video"
          ></iframe>
        {% elsif video_url contains 'youtube.com' or video_url contains 'youtu.be' %}
          {% if video_url contains 'v=' %}
            {% assign yt_id = section.settings.video_url | split: 'v=' | last | split: '&' | first %}
          {% else %}
            {% assign yt_id = section.settings.video_url | split: 'youtu.be/' | last | split: '?' | first %}
          {% endif %}
          <iframe
            src="https://www.youtube.com/embed/{{ yt_id }}"
            class="sachi-video__iframe"
            frameborder="0"
            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            title="Video"
          ></iframe>
        {% endif %}
      {% else %}
        <div class="sachi-video__placeholder">
          <p>Add a Vimeo or YouTube URL in the section settings.</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .sachi-video__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  @media (min-width: 750px) { .sachi-video__container { padding: 2rem; } }

  .sachi-video__wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .sachi-video__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .sachi-video__placeholder {
    position: absolute;
    inset: 0;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
  }
</style>

{% schema %}
{
  "name": "Sachi Video",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "Paste a Vimeo or YouTube page URL (e.g. https://vimeo.com/216321749)"
    }
  ],
  "presets": [
    {
      "name": "Sachi Video",
      "settings": {
        "video_url": "https://vimeo.com/216321749"
      }
    }
  ]
}
{% endschema %}
