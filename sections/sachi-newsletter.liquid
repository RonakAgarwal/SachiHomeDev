{% comment %}
  Sachi Newsletter - Paste in theme/sections/
  Email signup block "Want First Dibs?"
{% endcomment %}

<section class="sachi-newsletter section-{{ section.id }}-padding">
  <div class="sachi-newsletter__container">
    <h2 class="sachi-newsletter__heading">{{ section.settings.heading }}</h2>
    {% if section.settings.text != blank %}
      <p class="sachi-newsletter__text">{{ section.settings.text }}</p>
    {% endif %}
    {% form 'customer', class: 'sachi-newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="sachi-newsletter__fields">
        <input
          type="email"
          name="contact[email]"
          class="sachi-newsletter__input"
          value="{{ form.email }}"
          placeholder="{{ section.settings.placeholder }}"
          required
          aria-label="Email"
        >
        <button type="submit" class="sachi-newsletter__button">{{ section.settings.button_label }}</button>
      </div>
      {% if form.posted_successfully? %}
        <p class="sachi-newsletter__success">Thanks for subscribing!</p>
      {% endif %}
      {% if form.errors %}
        <p class="sachi-newsletter__error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

<style>
  .sachi-newsletter {
    background: #f9fafb;
    padding: 3rem 1rem;
  }
  @media (min-width: 750px) { .sachi-newsletter { padding: 4rem 2rem; } }

  .sachi-newsletter__container {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .sachi-newsletter__heading {
    font-weight: 700;
    font-size: 1.5rem;
    margin: 0 0 1rem;
  }
  @media (min-width: 750px) { .sachi-newsletter__heading { font-size: 1.875rem; } }

  .sachi-newsletter__text {
    font-size: 1.125rem;
    line-height: 1.625;
    margin: 0 0 2rem;
  }
  @media (min-width: 750px) { .sachi-newsletter__text { font-size: 1.5rem; } }

  .sachi-newsletter__form {
    max-width: 42rem;
    margin: 0 auto;
  }

  .sachi-newsletter__fields {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  @media (min-width: 750px) {
    .sachi-newsletter__fields {
      flex-direction: row;
      align-items: stretch;
    }
  }

  .sachi-newsletter__input {
    flex: 1;
    padding: 1rem 1rem;
    border: 1px solid #d1d5db;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
  }
  .sachi-newsletter__input::placeholder { color: #9ca3af; }

  .sachi-newsletter__button {
    background: #000;
    color: #fff;
    padding: 1rem 2rem;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s;
  }
  .sachi-newsletter__button:hover {
    background: #fff;
    color: #000;
    outline: 1px solid #000;
  }

  .sachi-newsletter__success { color: #059669; margin-top: 0.5rem; }
  .sachi-newsletter__error { color: #dc2626; margin-top: 0.5rem; }
</style>

{% schema %}
{
  "name": "Sachi Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Want First Dibs?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Join our email list and be the first to know about new limited edition products, material innovations, and lots of other fun updates."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "ENTER YOUR EMAIL ADDRESS"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SIGN UP"
    }
  ],
  "presets": [
    {
      "name": "Sachi Newsletter",
      "settings": {
        "heading": "Want First Dibs?",
        "text": "Join our email list and be the first to know about new limited edition products, material innovations, and lots of other fun updates.",
        "placeholder": "ENTER YOUR EMAIL ADDRESS",
        "button_label": "SIGN UP"
      }
    }
  ]
}
{% endschema %}
